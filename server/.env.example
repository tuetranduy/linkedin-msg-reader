# MongoDB Connection
# For local development with Docker:
MONGODB_URI=mongodb://app:apppassword@localhost:27017/linkedin_msg

# For MongoDB Atlas (production):
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/linkedin_msg?retryWrites=true&w=majority

# JWT Secret (change in production!)
JWT_SECRET=linkedin-msg-secret-key-change-in-production

# Server Port
PORT=3001
